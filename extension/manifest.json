{
  "manifest_version": 3,
  "name": "Leitor de Documentos IA",
  "version": "1.0.0",
  "description": "Leia PDF, DOCX, planilhas e CSV com IA (Gemini ou Groq).",
  "permissions": ["storage", "sidePanel"],
  "host_permissions": [
    "https://generativelanguage.googleapis.com/*",
    "https://api.groq.com/*"
  ],
  "action": {
    "default_title": "Leitor de Documentos IA",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["lib/pdf.worker.min.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
